{
  "name": "pact-plugins-example",
  "version": "1.0.0",
  "description": "Pact plugin system — custom protocol support",
  "private": true,
  "scripts": {
    "test": "npm run test:consumer && npm run test:provider",
    "test:consumer": "vitest run consumer.test.ts",
    "test:provider": "vitest run provider.test.ts",
    "pretest": "npm run install-plugin",
    "install-plugin": "pact-plugin-cli -y install https://github.com/mefellows/pact-matt-plugin/releases/download/v0.1.1/pact-matt-plugin-linux-x86_64.gz.sha256 || true"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@pact-foundation/pact": "file:../..",
    "@pact-foundation/pact-cli": "^18.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "axios": "^1.12.0",
    "express": "^5.1.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
